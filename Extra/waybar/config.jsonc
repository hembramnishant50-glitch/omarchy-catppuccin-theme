{
    "layer": "top",
    "position": "top",
    "mod": "dock",
    "height": 38,
    "exclusive": true,
    "passthrough": false,
    "gtk-layer-shell": true,
    "fixed-center": true,

    "modules-center": ["group/main-pill"],

    "group/main-pill": {
        "orientation": "horizontal",
        "modules": [
            "clock",
            "hyprland/window",
            "hyprland/workspaces",
            "pulseaudio",
            "network",
            "custom/antivirus",
            "battery"
        ]
    },

    "clock": {
        "format": "<b>{:%I:%M %p}</b>",
        "tooltip-format": "<tt><small>{calendar}</small></tt>",
        "calendar": {
            "mode": "month",
            "on-scroll": 1,
            "format": {
                "months": "<span color='#be9aef'><b>{}</b></span>",
                "days": "<span color='#cad3f5'><b>{}</b></span>",
                "weeks": "<span color='#5b6078'><b>W{}</b></span>",
                "weekdays": "<span color='#eed49f'><b>{}</b></span>",
                "today": "<span color='#be9aef'><b><u>{}</u></b></span>"
            }
        },
        "actions": {
            "on-click-right": "mode",
            "on-scroll-up": "shift_up",
            "on-scroll-down": "shift_down"
        }
    },

    "hyprland/window": {
        "format": "{class}", 
        "max-length": 35,
