    "hyprland/workspaces": {
        "format": "{name}",
        "on-click": "activate",
        "all-outputs": true,
        "sort-by-number": true,
        "persistent-workspaces": { "*": 3 }
    },

    "pulseaudio": {
        "format": "{icon}",
        "format-muted": "¾░Ø¤",
        "format-icons": { "default": ["¾░Ģ┐", "¾░¢Ć", "¾░ĢŠ"] },
        "on-click": "omarchy-launch-audio"
    },

    "network": {
        "format-wifi": "’ć½ ",
        "format-disconnected": "¾░¢¬ ",
        "on-click": "omarchy-launch-wifi",
        "tooltip-format": "{essid}"
    },

    "battery": {
        "states": { "warning": 30, "critical": 15 },
        "format": "{icon}",
        "format-icons": ["’ēä ", "’ēā ", "’ēé ", "’ēü ", "’ēĆ "],
        "on-click": "omarchy-menu power",
        "tooltip-format": "{capacity}%"
    }
