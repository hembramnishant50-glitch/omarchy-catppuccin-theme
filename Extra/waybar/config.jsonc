    "hyprland/workspaces": {
        "format": "{name}",
        "on-click": "activate",
        "all-outputs": true,
        "sort-by-number": true,
        "persistent-workspaces": {
            "*": 3
        }
    },

    "pulseaudio": {
        "format": "{icon}",
        "format-muted": "َ°‌ں",
        "format-icons": { "default": ["َ°•؟", "َ°–€", "َ°•¾"] },
        "on-click": "omarchy-launch-audio"
    },

    "network": {
        "format-wifi": "ï‡« ",
        "format-disconnected": "َ°–ھ ",
        "on-click": "omarchy-launch-wifi",
        "tooltip-format": "{essid}"
    },

    "custom/antivirus": {
        "exec": "if systemctl is-active --quiet clamonacc.service; then echo 'َ°•¥'; else echo ''; fi",
        "interval": 5,
        "format": "{}",
        "tooltip-format": "ClamAV Defender Active"
    },

    "battery": {
    "states": { "warning": 30, "critical": 15 },
    "format": "{icon} {capacity}%",       // â†گ added percentage
    "format-icons": ["ï‰„ ", "ï‰ƒ ", "ï‰‚ ", "ï‰پ ", "ï‰€ "],
    "on-click": "omarchy-menu power",
    "tooltip-format": "{capacity}%"
    },
