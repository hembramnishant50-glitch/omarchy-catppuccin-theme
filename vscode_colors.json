{
    "$schema": "vscode://schemas/color-theme",
    "name": "Omarchy Macchiato",
    "type": "dark",
    "colors": {
        // --- Base Colors ---
        "foreground": "#cad3f5",
        "disabledForeground": "#5b6078",
        "widget.shadow": "#181926",
        "selection.background": "#5b6078",
        "descriptionForeground": "#9399b2",
        "errorForeground": "#ed8796",
        "icon.foreground": "#be9aee",

        // --- Window & Action Colors ---
        "window.activeBorder": "#be9aee",
        "button.background": "#be9aee",
        "button.foreground": "#1e2030",
        "button.hoverBackground": "#c29df2",

        // --- Editor Colors ---
        "editor.background": "#24273a",
        "editor.foreground": "#cad3f5",
        "editorLineNumber.foreground": "#5b6078",
        "editorLineNumber.activeForeground": "#be9aee",
        "editorCursor.foreground": "#f4dbd6",
        "editor.selectionBackground": "#5b607860",
        "editor.lineHighlightBackground": "#363a4f",
        "editorIndentGuide.background": "#494d64",
        "editorIndentGuide.activeBackground": "#be9aee",

        // --- Sidebar & Activity Bar ---
        "activityBar.background": "#1e2030",
        "activityBar.foreground": "#be9aee",
        "activityBar.inactiveForeground": "#5b6078",
        "activityBarBadge.background": "#be9aee",
        "activityBarBadge.foreground": "#1e2030",

        "sideBar.background": "#1e2030",
        "sideBar.foreground": "#cad3f5",
        "sideBarTitle.foreground": "#be9aee",
        "sideBarSectionHeader.background": "#1e2030",
        "sideBarSectionHeader.foreground": "#cad3f5",

        // --- Tabs ---
        "editorGroupHeader.tabsBackground": "#181926",
        "tab.activeBackground": "#24273a",
        "tab.activeForeground": "#be9aee",
        "tab.inactiveBackground": "#1e2030",
        "tab.inactiveForeground": "#5b6078",
        "tab.activeBorder": "#be9aee",

        // --- Status Bar ---
        "statusBar.background": "#181926",
        "statusBar.foreground": "#cad3f5",
        "statusBarItem.remoteBackground": "#be9aee",
        "statusBarItem.remoteForeground": "#1e2030",

        // --- Terminal ---
        "terminal.background": "#24273a",
        "terminal.ansiBlack": "#494d64",
        "terminal.ansiRed": "#ed8796",
        "terminal.ansiGreen": "#a6da95",
        "terminal.ansiYellow": "#eed49f",
        "terminal.ansiBlue": "#8aadf4",
        "terminal.ansiMagenta": "#f5bde6",
        "terminal.ansiCyan": "#8bd5ca",
        "terminal.ansiWhite": "#b8c0e0",
        "terminal.ansiBrightMagenta": "#be9aee"
    },
    "tokenColors": [
        {
            "scope": ["comment", "punctuation.definition.comment"],
            "settings": {
                "foreground": "#6e738d",
                "fontStyle": "italic"
            }
        },
        {
            "scope": "keyword",
            "settings": {
                "foreground": "#c6a0f6"
            }
        },
        {
            "scope": "string",
            "settings": {
                "foreground": "#a6da95"
            }
        },
        {
            "scope": "entity.name.function",
            "settings": {
                "foreground": "#8aadf4"
            }
        },
        {
            "scope": "variable",
            "settings": {
                "foreground": "#cad3f5"
            }
        }
    ]
}